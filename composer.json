{
  "name": "pressgang-wp/quartermaster",
  "description": "Fluent WordPress query builder for WP_Query and WP_Term_Query — composable meta_query, tax_query and date_query, WordPress-native with no ORM or lock-in",
  "type": "library",
  "keywords": [
    "wordpress",
    "wp_query",
    "wp-query",
    "query-builder",
    "wordpress-query-builder",
    "fluent",
    "meta-query",
    "tax-query",
    "wp-term-query",
    "terms",
    "timber",
    "pressgang"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "PressGang\\Quartermaster\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PressGang\\Quartermaster\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "api-index": "wp capstan make api-index --force"
  }
}
